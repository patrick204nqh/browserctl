# Copy this file to .envrc and fill in your values.
# .envrc is listed in .gitignore and will never be committed.
# Use direnv (https://direnv.net) to load these automatically: `direnv allow`

# Required only for maintainers publishing releases to GitHub.
# Generate a personal access token at: https://github.com/settings/tokens
# Scopes needed: repo (for release-please to open PRs and create releases)
export GH_TOKEN="your_github_token_here"
